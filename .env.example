# =============================================================================
# BIGCOMMERCE CONFIGURATION
# =============================================================================
# These variables are used in different contexts:
# - VITE_* prefix: Used by Vite in the frontend and exposed to the browser
# - No prefix: Used by serverless functions (Netlify Functions, Node server)
#
# IMPORTANT: Keep both versions in sync!
# =============================================================================

# Frontend Variables (with VITE_ prefix)
VITE_BC_STORE_HASH=your_store_hash_here
VITE_BC_STOREFRONT_TOKEN=your_storefront_token_here

# Backend Variables (no prefix - for Netlify Functions & Node server)
BC_STORE_HASH=your_store_hash_here
BC_STOREFRONT_TOKEN=your_storefront_token_here

# BigCommerce REST API Token (for Cart and Checkout operations)
# To get this token:
# 1. Go to BigCommerce Admin > Settings > API > API Accounts
# 2. Create a V2/V3 API Account with Cart and Checkout scopes
# 3. Copy the Access Token here
BC_ACCESS_TOKEN=your_api_access_token_here

# =============================================================================
# SUPABASE CONFIGURATION
# =============================================================================
# Get these from your Supabase project dashboard at https://supabase.com/dashboard
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# =============================================================================
# API CONFIGURATION
# =============================================================================
# Leave this commented out to auto-detect:
#   - Development: http://localhost:8888/.netlify/functions (when using netlify dev)
#   - Production: /.netlify/functions
# Only set this if you need to override the auto-detection
# VITE_API_BASE=/.netlify/functions

# =============================================================================
# QUICKBOOKS ONLINE CONFIGURATION
# =============================================================================
# QuickBooks OAuth Credentials from developer.intuit.com
VITE_QB_CLIENT_ID=your_quickbooks_client_id
VITE_QB_CLIENT_SECRET=your_quickbooks_client_secret
VITE_QB_ENVIRONMENT=sandbox
VITE_QB_REDIRECT_URI=http://localhost:3000/admin/quickbooks/callback
VITE_QB_REDIRECT_URI_PROD=https://yourdomain.com/admin/quickbooks/callback

# =============================================================================
# HOW TO GET YOUR CREDENTIALS
# =============================================================================
#
# BIGCOMMERCE:
# 1. STORE HASH:
#    - Log into your BigCommerce store admin
#    - Look at the URL: https://store-{STORE_HASH}.mybigcommerce.com
#    - Copy the store hash from the URL
#
# 2. STOREFRONT TOKEN (GraphQL):
#    - Go to Advanced Settings > API Accounts
#    - Click "Create API Account" > "Create V2/V3 API Token"
#    - Select "Storefront API" scopes (at minimum: read products, categories)
#    - Copy the token after creation
#
# 3. ACCESS TOKEN (REST API):
#    - Same page as above (API Accounts)
#    - When creating the account, also enable these OAuth scopes:
#      - Carts: modify
#      - Checkouts: modify
#      - Orders: modify
#    - Copy the Access Token after creation
#
# QUICKBOOKS ONLINE:
# 1. Go to developer.intuit.com and sign in
# 2. Create a new app or select existing app
# 3. Go to Keys & credentials
# 4. Copy Client ID and Client Secret
# 5. Add redirect URIs for OAuth callback
# 6. Enable QuickBooks Payments in your app settings
#
# =============================================================================
